{
  "name": "pictochat-guestbook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/server.ts",
    "dev:client": "vite build --watch",
    "build": "vite build",
    "start": "bun run src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed": "bun run scripts/seed-admin.ts",
    "lint": "bunx ultracite check",
    "format": "bunx ultracite fix",
    "prepare": "bunx lefthook install",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.31.10",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.3",
    "ultracite": "7.8.4",
    "vite": "^8.1.3"
  }
}
